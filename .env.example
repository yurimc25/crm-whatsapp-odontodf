# Copie para .env.local para desenvolvimento local
# No Vercel: Settings → Environment Variables

# URL do seu WAHA (sem barra no final)
VITE_WAHA_URL=https://n8n-waha8.vxjlst.easypanel.host

# API Key definida no Easypanel (WAHA_API_KEY)
VITE_WAHA_API_KEY=sua_api_key_aqui

# Nome da sessão WAHA (padrão: default)
VITE_WAHA_SESSION=default

# Use "true" para rodar com dados fictícios sem precisar do WAHA
VITE_USE_MOCK=false

# Google Contacts (Vercel server-side only — não colocar no frontend)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REFRESH_TOKEN=seu_refresh_token

# Chave interna para comunicação frontend → api/contacts
VITE_INTERNAL_API_KEY=mesma_chave_do_internal_api_key
INTERNAL_API_KEY=gere_uma_chave_longa_aqui

# Senhas dos operadores (uma por operador)
OPERATOR_YURI_PASS=troque_pela_senha_real
OPERATOR_ANA_PASS=troque_pela_senha_real
OPERATOR_PATRICIA_PASS=troque_pela_senha_real
