# Copie para .env.local para desenvolvimento local
# No Vercel: Settings → Environment Variables

# URL do seu WAHA (sem barra no final)
VITE_WAHA_URL=https://n8n-waha8.vxjlst.easypanel.host

# API Key definida no Easypanel (WAHA_API_KEY)
VITE_WAHA_API_KEY=sua_api_key_aqui

# Nome da sessão WAHA (padrão: default)
VITE_WAHA_SESSION=default

# Use "true" para rodar com dados fictícios sem precisar do WAHA
VITE_USE_MOCK=false
